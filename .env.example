# ============================================================================
# AWS S3 & SNOWFLAKE PIPELINE CONFIGURATION
# Copy this file to '.env' and fill in your actual credentials.
# ============================================================================

# --- AWS S3 CONFIGURATION ---
AWS_ACCESS_KEY_ID=your_aws_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key_here
AWS_REGION=us-east-1
S3_BUCKET_NAME=my-healthcare-pipeline-data

# --- SNOWFLAKE CONFIGURATION ---
# Account identifier format: xy12345.us-east-1 OR myorg-myaccount
SNOWFLAKE_ACCOUNT=your_snowflake_account_identifier
SNOWFLAKE_USER=your_snowflake_username
SNOWFLAKE_PASSWORD=your_snowflake_password
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=HEALTHCARE_DB
SNOWFLAKE_ROLE=ACCOUNTADMIN

# --- LOCAL DUCKDB BACKUP MODE ---
# Set to 'true' to execute locally with DuckDB if Snowflake keys are not provided
USE_LOCAL_DUCKDB=true
